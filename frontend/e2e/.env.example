# Copy to frontend/e2e/.env (gitignored) and fill in the values.
# Used by the Playwright E2E suite and capture-docs-screenshots.mjs.
# Inline environment variables (E2E_SR_PASS=... npx playwright test) override these.

# Required: StarRocks root password for the test cluster
E2E_SR_PASS=

# Optional overrides (defaults shown)
# E2E_SR_HOST=192.168.10.5
# E2E_SR_PORT=9030
# E2E_SR_USER=root
